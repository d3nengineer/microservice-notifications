APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=microservice_notification
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=
NOTIFICATION_LOCK_CACHE_STORE=redis
NOTIFICATION_IDEMPOTENCY_LOCK_TTL_SECONDS=10
NOTIFICATION_IDEMPOTENCY_LOCK_BLOCK_SECONDS=3
NOTIFICATION_RATE_LIMIT_CACHE_STORE=redis
NOTIFICATION_RATE_LIMIT_PREFIX=notification-gateways
NOTIFICATION_EMAIL_RATE_LIMIT_ATTEMPTS=60
NOTIFICATION_EMAIL_RATE_LIMIT_DECAY_SECONDS=60
NOTIFICATION_SMS_RATE_LIMIT_ATTEMPTS=30
NOTIFICATION_SMS_RATE_LIMIT_DECAY_SECONDS=60
NOTIFICATION_HISTORY_CACHE_ENABLED=false
NOTIFICATION_HISTORY_CACHE_STORE=redis
NOTIFICATION_HISTORY_CACHE_TTL_SECONDS=60

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

NOTIFICATION_KAFKA_PRODUCER=unavailable
NOTIFICATION_KAFKA_CONSUMER=unavailable
NOTIFICATION_KAFKA_TOPIC_HIGH=notifications.high
NOTIFICATION_KAFKA_TOPIC_NORMAL=notifications.normal
NOTIFICATION_KAFKA_TOPIC_LOW=notifications.low
NOTIFICATION_OUTBOX_PUBLISH_LIMIT=100
NOTIFICATION_OUTBOX_MAX_ATTEMPTS=3
NOTIFICATION_OUTBOX_BACKOFF_SECONDS=60
NOTIFICATION_DELIVERY_MAX_ATTEMPTS=3
NOTIFICATION_DELIVERY_BACKOFF_SECONDS=60
NOTIFICATION_DELIVERY_MAX_BACKOFF_SECONDS=900
NOTIFICATION_GATEWAY_UNAVAILABLE_RESULT=temporary_failed
NOTIFICATION_EMAIL_GATEWAY=unavailable
NOTIFICATION_SMS_GATEWAY=unavailable

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
